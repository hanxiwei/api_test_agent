# 这是一个环境变量配置模板
# 请将此文件复制一份并重命名为 .env，然后填入你的真实信息

# LLM 模型提供商，可以使用 openai 或者兼容 openai 接口的其他服务（比如 deepseek）
OPENAI_API_KEY="your_api_key_here"

# 如果你使用的是 DeepSeek，可以将 base url 改为: https://api.deepseek.com/v1
OPENAI_BASE_URL="https://api.openai.com/v1"

# 使用的模型名称，例如 gpt-4o-mini 或 deepseek-chat
LLM_MODEL="gpt-4o-mini"
